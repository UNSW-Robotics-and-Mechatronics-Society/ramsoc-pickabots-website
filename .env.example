# ── Clerk ──────────────────────────────────────────────────────────
# Shared instance with the sumobots site (dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/bid
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/bid

# ── Supabase ───────────────────────────────────────────────────────
# Shared project with the sumobots site (supabase.com/dashboard → API)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Publishable/anon key (safe for the browser) — enables Supabase Realtime on the
# public page so bidding open/close updates live. Without it, the page falls
# back to polling every ~5s.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Admin access ───────────────────────────────────────────────────
# Secret code a signed-in user enters at /admin to be granted the admin role
ADMIN_ACCESS_CODE=
